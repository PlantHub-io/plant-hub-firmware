# firmware/devices/secrets.yaml.example
#
# Reference copy of secrets.yaml. The actual secrets.yaml is committed to the
# repo with alpha-test defaults, so you do NOT need to copy this file.
#
# This file exists as documentation for users running their own backend.
# To point firmware at a custom backend:
#   1. Edit firmware/devices/secrets.yaml directly
#   2. Change backend_url and device_provisioning_key to match your server
#
# Wi-Fi credentials are NOT stored here — the device collects them via
# the captive portal on first boot.


# ---- Device access passwords -------------------------------------------
# Password for the fallback Wi-Fi AP the device raises when it has no
# saved credentials. Testers connect a phone to "PlantHub-XXXX" using this.
fallback_ap_password: "planthub-setup"

# OTA update password. Protects over-the-air firmware updates on the LAN.
ota_password: "planthub-ota"

# Local web UI password (port 80). Shown when you open the device's page
# in a browser. Purely for on-device monitoring; does not affect onboarding.
web_password: "admin"


# ---- PlantHub backend --------------------------------------------------
# Alpha testers: leave as-is — this is the hosted backend.
backend_url: "https://planthub.online"

# Shared alpha-test provisioning key. The backend validates this against
# its configured `app.device-provisioning.api-key`. It will be rotated to
# per-tester keys before GA; for the alpha, everyone uses the same one.
device_provisioning_key: "mfrGhM2Agu5JIALJPITG4oHW2RYbg6FtXKOHscbF3CQ="
